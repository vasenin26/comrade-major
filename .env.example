# Скопируйте в .env и измените под своё окружение:
# cp .env.example .env

# --- Аудио ---
SAMPLE_RATE=16000
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=500

# --- STT (faster-whisper) ---
# tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=small

# --- Primary mind ---
# local  — HuggingFace transformers в процессе
# openai — OpenAI-compatible HTTP API
PRIMARY_MIND_PROVIDER=local
PRIMARY_MIND_MODEL=Qwen/Qwen2.5-0.5B-Instruct
PRIMARY_MIND_DEVICE=auto
PRIMARY_MIND_MAX_NEW_TOKENS=256
PRIMARY_MIND_TEMPERATURE=0.7
# PRIMARY_MIND_SYSTEM_PROMPT=...

# Только для PRIMARY_MIND_PROVIDER=openai
# PRIMARY_MIND_API_KEY=sk-your-key-here
# PRIMARY_MIND_BASE_URL=https://api.openai.com/v1
# Примеры base_url:
# DeepSeek: https://api.deepseek.com/v1
# Groq:     https://api.groq.com/openai/v1

# --- Inner voice (optional overrides; defaults to primary profile) ---
# INNER_VOICE_PROVIDER=local
# INNER_VOICE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# INNER_VOICE_DEVICE=auto
# INNER_VOICE_MAX_NEW_TOKENS=128
# INNER_VOICE_TEMPERATURE=0.5
# INNER_VOICE_API_KEY=
# INNER_VOICE_BASE_URL=
# INNER_VOICE_SYSTEM_PROMPT=...

MIND_CONTEXT_TRIM_COUNT=2

# Legacy aliases still accepted: LLM_PROVIDER, LLM_MODEL, LLM_API_KEY, ...

# --- Прочее ---
LOG_DIR=logs
